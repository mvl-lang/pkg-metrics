// pkg.metrics tests

use std.collections.{Map}

// ── metric_key encoding ───────────────────────────────────────────────────────

test fn key_no_tags() -> Unit {
    let no_tags: Map[String, String] = Map::new();
    assert_eq(metric_key("http_requests_total", no_tags), "http_requests_total")
}

test fn key_single_tag() -> Unit {
    assert_eq(
        metric_key("http_requests_total", {"method": "GET"}),
        "http_requests_total{method=\"GET\"}"
    )
}

test fn key_tags_sorted() -> Unit {
    assert_eq(
        metric_key("req", {"status": "200", "method": "GET"}),
        "req{method=\"GET\",status=\"200\"}"
    )
}

test fn key_three_tags_sorted() -> Unit {
    assert_eq(
        metric_key("api_calls_total", {"handler": "create_user", "method": "POST", "status": "201"}),
        "api_calls_total{handler=\"create_user\",method=\"POST\",status=\"201\"}"
    )
}

// ── Counter type ──────────────────────────────────────────────────────────────

test fn counter_construction() -> Unit {
    let tags: Map[String, String] = {"method": "GET", "status": "200"};
    let c: Counter = Counter { name: "http_requests_total", tags: tags, value: 0 };
    assert_eq(c.name, "http_requests_total");
    assert_eq(c.value, 0)
}

test fn counter_name_follows_convention() -> Unit {
    let c: Counter = Counter { name: "http_requests_total", tags: {"_": "_"}, value: 42 };
    assert(c.name.ends_with("_total"))
}

test fn counter_value_is_non_negative() -> Unit {
    let c: Counter = Counter { name: "errors_total", tags: {"_": "_"}, value: 100 };
    assert(c.value >= 0)
}

test fn counter_with_multiple_tags() -> Unit {
    let tags: Map[String, String] = {"method": "POST", "status": "201", "handler": "create_user"};
    let c: Counter = Counter { name: "api_calls_total", tags: tags, value: 5 };
    assert_eq(c.tags.get("method"), Some("POST"));
    assert_eq(c.tags.get("status"), Some("201"));
    assert_eq(c.tags.get("handler"), Some("create_user"))
}

// ── Gauge type ────────────────────────────────────────────────────────────────

test fn gauge_construction() -> Unit {
    let g: Gauge = Gauge { name: "connections_active", tags: {"_": "_"}, value: 5.0 };
    assert_eq(g.name, "connections_active");
    assert_eq(g.value, 5.0)
}

test fn gauge_can_be_negative() -> Unit {
    let g: Gauge = Gauge { name: "temperature_celsius", tags: {"_": "_"}, value: -10.5 };
    assert(g.value < 0.0)
}

test fn gauge_with_tags() -> Unit {
    let tags: Map[String, String] = {"instance": "web-1", "region": "eu-west"};
    let g: Gauge = Gauge { name: "queue_depth", tags: tags, value: 42.0 };
    assert_eq(g.tags.get("instance"), Some("web-1"));
    assert_eq(g.tags.get("region"), Some("eu-west"))
}

test fn gauge_zero_value() -> Unit {
    let g: Gauge = Gauge { name: "idle_workers", tags: {"_": "_"}, value: 0.0 };
    assert_eq(g.value, 0.0)
}

// ── Bucket type ───────────────────────────────────────────────────────────────

test fn bucket_construction() -> Unit {
    let b: Bucket = Bucket { le: 0.1, count: 50 };
    assert_eq(b.le, 0.1);
    assert_eq(b.count, 50)
}

test fn bucket_le_boundary() -> Unit {
    let b: Bucket = Bucket { le: 1.0, count: 100 };
    assert_eq(b.le, 1.0)
}

test fn bucket_zero_count() -> Unit {
    let b: Bucket = Bucket { le: 0.001, count: 0 };
    assert_eq(b.count, 0)
}

// ── Histogram type ────────────────────────────────────────────────────────────

test fn histogram_construction() -> Unit {
    let buckets: List[Bucket] = [
        Bucket { le: 0.005, count: 10 },
        Bucket { le: 0.01,  count: 25 },
        Bucket { le: 0.025, count: 50 },
    ];
    let h: Histogram = Histogram {
        name:    "http_request_duration_seconds",
        tags:    {"_": "_"},
        buckets: buckets,
        sum:     12.5,
        count:   100,
    };
    assert_eq(h.name, "http_request_duration_seconds");
    assert_eq(h.count, 100);
    assert_eq(h.sum, 12.5)
}

test fn histogram_name_has_unit_suffix() -> Unit {
    let h: Histogram = Histogram {
        name: "response_size_bytes", tags: {"_": "_"}, buckets: [], sum: 0.0, count: 0,
    };
    assert(h.name.ends_with("_bytes"))
}

test fn histogram_empty_buckets() -> Unit {
    let h: Histogram = Histogram {
        name: "latency_seconds", tags: {"_": "_"}, buckets: [], sum: 0.0, count: 0,
    };
    assert_eq(h.buckets.len(), 0)
}

test fn histogram_buckets_ordered() -> Unit {
    let buckets: List[Bucket] = [
        Bucket { le: 0.1, count: 10 },
        Bucket { le: 0.5, count: 30 },
        Bucket { le: 1.0, count: 50 },
    ];
    let first: Bucket = match buckets.get(0) {
        Some(b) => b,
        None    => Bucket { le: 0.0, count: 0 },
    };
    let last: Bucket = match buckets.get(2) {
        Some(b) => b,
        None    => Bucket { le: 0.0, count: 0 },
    };
    assert(first.le < last.le)
}

test fn histogram_sum_and_count() -> Unit {
    let h: Histogram = Histogram {
        name: "request_duration_seconds", tags: {"_": "_"}, buckets: [],
        sum: 123.456, count: 1000,
    };
    assert_eq(h.sum, 123.456);
    assert_eq(h.count, 1000)
}

// ── make_default_buckets ──────────────────────────────────────────────────────

test fn default_buckets_count() -> Unit {
    let bs: List[Bucket] = make_default_buckets();
    assert_eq(bs.len(), 10)
}

test fn default_buckets_boundaries() -> Unit {
    let bs: List[Bucket] = make_default_buckets();
    let first: Bucket = match bs.get(0) {
        Some(b) => b,
        None    => Bucket { le: 0.0, count: -1 },
    };
    let last: Bucket = match bs.get(9) {
        Some(b) => b,
        None    => Bucket { le: 0.0, count: -1 },
    };
    assert_eq(first.le, 1.0);
    assert_eq(last.le, 5000.0)
}

test fn default_buckets_all_zero_counts() -> Unit {
    let bs: List[Bucket] = make_default_buckets();
    let b: Bucket = match bs.get(0) {
        Some(b) => b,
        None    => Bucket { le: 0.0, count: -1 },
    };
    assert_eq(b.count, 0)
}

// ── observe_into ──────────────────────────────────────────────────────────────

test fn observe_into_increments_count_and_sum() -> Unit {
    let h: Histogram = Histogram {
        name: "req_ms", tags: Map::new(), buckets: [], sum: 0.0, count: 0,
    };
    let h2: Histogram = observe_into(h, 42.0);
    assert_eq(h2.count, 1);
    assert_eq(h2.sum, 42.0)
}

test fn observe_into_increments_matching_bucket() -> Unit {
    let bs: List[Bucket] = [Bucket { le: 100.0, count: 0 }];
    let h: Histogram = Histogram {
        name: "req_ms", tags: Map::new(), buckets: bs, sum: 0.0, count: 0,
    };
    let h2: Histogram = observe_into(h, 50.0);
    let b: Bucket = match h2.buckets.get(0) {
        Some(bkt) => bkt,
        None      => Bucket { le: 0.0, count: -1 },
    };
    assert_eq(b.count, 1)
}

test fn observe_into_skips_bucket_above_value() -> Unit {
    let bs: List[Bucket] = [Bucket { le: 10.0, count: 0 }];
    let h: Histogram = Histogram {
        name: "req_ms", tags: Map::new(), buckets: bs, sum: 0.0, count: 0,
    };
    let h2: Histogram = observe_into(h, 50.0);
    let b: Bucket = match h2.buckets.get(0) {
        Some(bkt) => bkt,
        None      => Bucket { le: 0.0, count: -1 },
    };
    assert_eq(b.count, 0)
}

test fn observe_into_preserves_bucket_count() -> Unit {
    let bs: List[Bucket] = make_default_buckets();
    let h: Histogram = Histogram {
        name: "req_ms", tags: Map::new(), buckets: bs, sum: 0.0, count: 0,
    };
    let h2: Histogram = observe_into(h, 30.0);
    assert_eq(h2.buckets.len(), 10)
}

// ── standard_labels ───────────────────────────────────────────────────────────

test fn standard_labels_empty_tags() -> Unit {
    let empty: Map[String, String] = Map::new();
    assert_eq(standard_labels(empty), "")
}

test fn standard_labels_single_tag() -> Unit {
    assert_eq(
        standard_labels({"job": "api"}),
        "{job=\"api\"}"
    )
}

test fn standard_labels_multiple_tags_sorted() -> Unit {
    assert_eq(
        standard_labels({"z": "last", "a": "first"}),
        "{a=\"first\",z=\"last\"}"
    )
}

// ── bucket_labels ─────────────────────────────────────────────────────────────

test fn bucket_labels_empty_tags() -> Unit {
    let empty: Map[String, String] = Map::new();
    assert_eq(bucket_labels(empty, "0.1"), "{le=\"0.1\"}")
}

test fn bucket_labels_plus_inf_no_tags() -> Unit {
    let empty: Map[String, String] = Map::new();
    assert_eq(bucket_labels(empty, "+Inf"), "{le=\"+Inf\"}")
}

test fn bucket_labels_with_tags() -> Unit {
    assert_eq(
        bucket_labels({"env": "prod"}, "0.5"),
        "{le=\"0.5\",env=\"prod\"}"
    )
}

// ── http_200 / http_404 ───────────────────────────────────────────────────────

test fn http_200_status_line() -> Unit {
    let resp: String = http_200("hello");
    assert(resp.starts_with("HTTP/1.1 200 OK"))
}

test fn http_200_content_length() -> Unit {
    let resp: String = http_200("hello");
    assert(resp.contains("Content-Length: 5"))
}

test fn http_200_body_appended() -> Unit {
    let resp: String = http_200("hello");
    assert(resp.ends_with("hello"))
}

test fn http_200_empty_body() -> Unit {
    let resp: String = http_200("");
    assert(resp.contains("Content-Length: 0"))
}

test fn http_404_status_line() -> Unit {
    let resp: String = http_404();
    assert(resp.starts_with("HTTP/1.1 404 Not Found"))
}

// ── format_prometheus ─────────────────────────────────────────────────────────

test fn format_prometheus_empty_maps() -> Unit {
    let result: String = format_prometheus(Map::new(), Map::new(), Map::new());
    assert_eq(result, "")
}

test fn format_prometheus_single_counter() -> Unit {
    let counters: Map[String, Int] = {"http_requests_total": 42};
    let result: String = format_prometheus(counters, Map::new(), Map::new());
    assert(result.contains("http_requests_total"))
}

test fn format_prometheus_counter_ends_with_newline() -> Unit {
    let counters: Map[String, Int] = {"errors_total": 3};
    let result: String = format_prometheus(counters, Map::new(), Map::new());
    assert(result.ends_with("\n"))
}

test fn format_prometheus_single_gauge() -> Unit {
    let gauges: Map[String, Float] = {"connections_active": 5.0};
    let result: String = format_prometheus(Map::new(), gauges, Map::new());
    assert(result.contains("connections_active"))
}

test fn format_prometheus_histogram_emits_bucket_sum_count() -> Unit {
    let bs: List[Bucket] = [Bucket { le: 100.0, count: 2 }];
    let h: Histogram = Histogram {
        name: "req_ms", tags: Map::new(), buckets: bs, sum: 180.0, count: 2,
    };
    let histograms: Map[String, Histogram] = {"req_ms": h};
    let result: String = format_prometheus(Map::new(), Map::new(), histograms);
    assert(result.contains("req_ms_bucket"));
    assert(result.contains("req_ms_sum"));
    assert(result.contains("req_ms_count"))
}

test fn format_prometheus_histogram_plus_inf_bucket() -> Unit {
    let bs: List[Bucket] = [Bucket { le: 50.0, count: 1 }];
    let h: Histogram = Histogram {
        name: "latency_ms", tags: Map::new(), buckets: bs, sum: 30.0, count: 1,
    };
    let histograms: Map[String, Histogram] = {"latency_ms": h};
    let result: String = format_prometheus(Map::new(), Map::new(), histograms);
    assert(result.contains("+Inf"))
}

test fn format_prometheus_histogram_with_tags() -> Unit {
    let bs: List[Bucket] = [Bucket { le: 10.0, count: 0 }];
    let h: Histogram = Histogram {
        name: "req_ms", tags: {"env": "prod"}, buckets: bs, sum: 0.0, count: 0,
    };
    let histograms: Map[String, Histogram] = {"req_ms{env=\"prod\"}": h};
    let result: String = format_prometheus(Map::new(), Map::new(), histograms);
    assert(result.contains("env=\"prod\""))
}
